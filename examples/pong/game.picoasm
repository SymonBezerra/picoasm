{ BANK_1 }

# 5 $0xB000 ; pad len

# 15 $0xB001 ; y pos

:BLIT

# *0xB000 $0xB0A0

# *0xB001 $0xB0A1

:DRAW_LOOP

^ $0x8000 ; vram region
# *0xB0A0 $0xB0A2
:SHIFT_VRAM_LOOP
> 4
- 1 $0xB0A2
@ *0xB0A2 :SHIFT_VRAM_LOOP

> 3
# *0xB0A1 $_

^ $0xD800 ; fg oam region
# *0xB0A0 $0xB0A2
:SHIFT_OAM_LOOP
> 4
- 1 $0xB0A2
@ *0xB0A2 :SHIFT_OAM_LOOP

> 3
# 0b00001000 $_

- 1 $0xB0A0
- 1 $0xB0A1

@ *0xB0A0 :DRAW_LOOP

@ 1 :BLIT