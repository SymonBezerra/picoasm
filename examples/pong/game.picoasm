{ BANK_1 }

%PAD_LEN $0xB000
# 5 %PAD_LEN
%CONTENT_PAD_LEN *0xB000

%PAD_X $0xB002
# 5 %PAD_X

%CONTENT_PAD_X *0xB002

%PAD_Y $0xB003
# 15 $0xB003

%CONTENT_PAD_Y *0xB003

% ATTR_SHIFT 3
% VRAM_XSHIFT 2

:BLIT

# %CONTENT_PAD_LEN $0xB001 ; accumulator
:PAD_DRAW_LOOP
^ $0x8000
> *0xB001
> %VRAM_XSHIFT
# *0xB001 $_
^ $0xD000
> *0xB001
> %ATTR_SHIFT
# 0b00001000 $_
# 0 $0xB001
@ *0xB001 :PAD_DRAW_LOOP

.

!

@ 1 :BLIT